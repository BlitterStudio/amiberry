{
  "name": "amiberry",
  "version": "8.1.5",
  "description": "Optimized Amiga emulator for various platforms",
  "homepage": "https://amiberry.com",
  "dependencies": [
    "sdl3",
    {
      "name": "sdl3-image",
      "features": [
        "png"
      ]
    },
    "libflac",
    {
      "name": "mpg123",
      "platform": "!(windows & arm64)"
    },
    "libpng",
    "zlib",
    "zstd",
    "enet",
    "libiconv",
    "curl",
    "nlohmann-json"
  ]
}
