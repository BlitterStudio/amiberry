    <string name="about_title">About Amiberry</string>
    <string name="about_description">Amiberry is an optimized Amiga emulator, bringing the classic Amiga experience to modern devices. Based on UAE (Unix Amiga Emulator), it supports a wide range of Amiga models from the A500 to the A4000, CD32, and CDTV.</string>
    <string name="about_version_label">Version</string>
    <string name="about_license_title">License</string>
    <string name="about_license_body">GNU General Public License v3 (GPLv3)\n\nAmiberry is free and open-source software. You are free to use, modify, and distribute it under the terms of the GPLv3.</string>
    <string name="about_links_title">Links</string>
    <string name="about_link_github">Source Code (GitHub)</string>
    <string name="about_link_wiki">Wiki &amp; Documentation</string>
    <string name="about_link_discord">Community (Discord)</string>
    <string name="about_link_privacy">Privacy Policy</string>
    <string name="about_credits_title">Credits</string>
    <string name="about_credits_body">Created by Dimitris Panokostas (MiDWaN)\n\nBased on WinUAE by Toni Wilen, and earlier work by Bernd Schmidt and the UAE team.\n\nUses SDL, Dear ImGui, and other open-source libraries.</string>

    <string name="welcome_title">Welcome to Amiberry</string>
    <string name="welcome_message">Amiberry is an Amiga emulator. To get started, you\'ll need a Kickstart ROM file — this is the Amiga\'s operating system firmware. Import one from the Files tab, then choose an Amiga model and insert a floppy or CD image to start emulating.</string>
    <string name="welcome_help_link">Learn more</string>
    <string name="welcome_dismiss">Got it</string>

