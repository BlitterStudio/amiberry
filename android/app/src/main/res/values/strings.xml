    <string name="about_title">About Amiberry</string>
    <string name="about_description">Amiberry is an optimized Amiga emulator, bringing the classic Amiga experience to modern devices. Based on UAE (Unix Amiga Emulator), it supports a wide range of Amiga models from the A500 to the A4000, CD32, and CDTV.</string>
    <string name="about_version_label">Version</string>
    <string name="about_support_title">Support Info</string>
    <string name="about_copy_support_info">Copy support info</string>
    <string name="about_license_title">License</string>
    <string name="about_license_body">GNU General Public License v3 (GPLv3)\n\nAmiberry is free and open-source software. You are free to use, modify, and distribute it under the terms of the GPLv3.</string>
    <string name="about_links_title">Links</string>
