<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash screen theme applied to MainActivity in the manifest.
         SplashScreen API handles the animated icon on Android 12+ and
         provides a consistent experience back to API 23. -->
    <style name="Theme.Amiberry.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AppCompat.DayNight.NoActionBar</item>
    </style>
</resources>
