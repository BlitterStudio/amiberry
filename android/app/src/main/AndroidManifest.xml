<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Hardware feature declarations for Play Store device filtering -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.hardware.wifi" android:required="false" />
    <uses-feature android:name="android.hardware.telephony" android:required="false" />

    <!-- Android TV support (required="false" = same APK for phone + TV) -->
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <!-- Bluetooth is optional — used for game controllers, not required for core functionality -->
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Bluetooth controller support (Steam Controller BLE, HID devices) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Haptic feedback for game controllers -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/tv_banner"
        android:hasFragileUserData="true"
        android:requestLegacyExternalStorage="true">

        <!-- Native Compose UI (launcher) -->
        <activity android:name="com.blitterstudio.amiberry.ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Amiberry.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Android TV launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SDL emulator activity (launched by native UI) -->
        <activity android:name="com.blitterstudio.amiberry.AmiberryActivity"
            android:process=":sdl"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|uiMode|navigation"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:enableOnBackInvokedCallback="true"
            android:exported="false">
            <meta-data android:name="SDL_MAIN_LIBRARY_NAMES" android:value="amiberry" />
        </activity>
    </application>

</manifest>
