<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- JIT compilation support (ARM64 dynamic recompiler) -->
	<!-- Note: this entitlement is required for JIT but may not be granted
	     for App Store builds. Interpreter-only mode works without it. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>
